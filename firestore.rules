rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Setiap pengguna hanya boleh baca & tulis dokumen progresnya sendiri,
    // yang di-key pakai uid akun Google mereka (lihat lib/ProgressContext.tsx).
    // Tidak ada seorang pun (termasuk pengguna lain yang login) yang bisa
    // membaca/mengubah data milik pengguna lain.
    match /progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
